# [PROJECT_NAME] — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# All variables listed here are REQUIRED unless marked [OPTIONAL].
#
# Production secrets must be stored in a secret manager (SSM, Vault, etc.)
# and loaded at runtime — never hardcoded or committed.

# ============================================================
# Application
# ============================================================

# Application environment: development | staging | production
APP_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info

# [OPTIONAL] Enable debug mode (never true in production)
DEBUG=false

# ============================================================
# Server
# ============================================================

# Port the service listens on
PORT=8080

# Host the service binds to (use 0.0.0.0 for Docker)
HOST=0.0.0.0

# ============================================================
# Database
# ============================================================

# Full database connection URL
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://user:password@localhost:5432/[PROJECT_NAME]_dev?sslmode=disable

# ============================================================
# Authentication
# ============================================================

# Secret key used for signing tokens / sessions (minimum 32 bytes, high entropy)
SECRET_KEY=replace-with-a-long-random-string-before-use

# [OPTIONAL] JWT token expiry in seconds (default: 3600)
TOKEN_EXPIRY_SECONDS=3600

# ============================================================
# External Services
# ============================================================

# [SERVICE_NAME] API base URL
# SERVICE_NAME_URL=https://api.example.com/v1

# [SERVICE_NAME] API key
# SERVICE_NAME_API_KEY=replace-with-real-key

# ============================================================
# AWS (if applicable)
# ============================================================

# AWS region
# AWS_REGION=eu-west-1

# AWS profile (for local dev; use IAM roles in production)
# AWS_PROFILE=default

# ============================================================
# Redis / Cache (if applicable)
# ============================================================

# Redis connection URL
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# Observability
# ============================================================

# [OPTIONAL] OpenTelemetry collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# [OPTIONAL] Service name for tracing
# OTEL_SERVICE_NAME=[PROJECT_NAME]
